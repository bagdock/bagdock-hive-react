{
  "name": "@bagdock/hive-react",
  "version": "0.5.0",
  "description": "Bagdock Hive React SDK — embeddable AI chat, rental, and access widgets for self-storage",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./map": {
      "types": "./dist/map.d.ts",
      "import": "./dist/map.mjs",
      "require": "./dist/map.js"
    },
    "./map/mapbox": {
      "types": "./dist/map/mapbox.d.ts",
      "import": "./dist/map/mapbox.mjs",
      "require": "./dist/map/mapbox.js"
    },
    "./map/maptiler": {
      "types": "./dist/map/maptiler.d.ts",
      "import": "./dist/map/maptiler.mjs",
      "require": "./dist/map/maptiler.js"
    },
    "./map/stadia": {
      "types": "./dist/map/stadia.d.ts",
      "import": "./dist/map/stadia.mjs",
      "require": "./dist/map/stadia.js"
    },
    "./map/radar": {
      "types": "./dist/map/radar.d.ts",
      "import": "./dist/map/radar.mjs",
      "require": "./dist/map/radar.js"
    },
    "./map/google": {
      "types": "./dist/map/google.d.ts",
      "import": "./dist/map/google.mjs",
      "require": "./dist/map/google.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "lucide-react": ">=0.300.0",
    "mapbox-gl": ">=2.0.0",
    "@maptiler/sdk": ">=2.0.0",
    "maplibre-gl": ">=3.0.0",
    "radar-sdk-js": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": false
    },
    "mapbox-gl": {
      "optional": true
    },
    "@maptiler/sdk": {
      "optional": true
    },
    "maplibre-gl": {
      "optional": true
    },
    "radar-sdk-js": {
      "optional": true
    }
  },
  "dependencies": {
    "@bagdock/hive": "^0.3.0",
    "@bagdock/pii-patterns": "^0.1.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bagdock/bagdock-hive-react"
  },
  "homepage": "https://bagdock.com/docs/hive-react",
  "bugs": "https://github.com/bagdock/bagdock-hive-react/issues",
  "keywords": [
    "bagdock",
    "hive",
    "react",
    "embed",
    "ai",
    "chat",
    "rental",
    "widget",
    "self-storage",
    "cora",
    "agent"
  ],
  "license": "MIT",
  "sideEffects": false
}
